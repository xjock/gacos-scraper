function binaryToStr(str){
                var result = [];
                var list = str.split(" ");
                for(var i=0;i<list.length;i++){
                     var item = list[i];
                     var asciiCode = parseInt(item,16);
                     var charValue = String.fromCharCode(asciiCode);
                     result.push(charValue);
                }
                return result.join("");
            }
$(function() {
                //当点击"一键上传"按钮的时候,触发表单中的浏览文件的操作
                $("#getkml").click(function() {
                    $("#uploadfile").click();   
                })
                 
                //当选择好上传文件后,执行提交表单的操作
                
                $("#uploadfile").change(function() {
                    var reader = new FileReader();
                    reader.onload = function() {
                    	var flag=1;var N,W,E,S;
                    	if (this.result.indexOf("<north>")>0) {
                    		N=this.result.substring(this.result.indexOf("<north>")+7,this.result.indexOf("</north>"));
	                        W=this.result.substring(this.result.indexOf("<west>")+6,this.result.indexOf("</west>"));
	                        E=this.result.substring(this.result.indexOf("<east>")+6,this.result.indexOf("</east>"));
	                        S=this.result.substring(this.result.indexOf("<south>")+7,this.result.indexOf("</south>"));
	                        flag=0;
                    	}
                        if (this.result.indexOf("<coordinates>")>0) {
                        	var N=this.result.substring(this.result.indexOf("<coordinates>")+13,this.result.indexOf("</coordinates>"));
							N=N.trim();
							var arr1=N.split(' ');
							var arr2=[];
							for (var i = 0; i < arr1.length; i++) {
								var dex=arr1[i].lastIndexOf(',');
								arr2[i]=arr1[i].substring(0,dex);
							}
							var arrx=[],arry=[];
							for (var i = 0; i < arr2.length; i++) {
								var dex=arr2[i].lastIndexOf(',');
								arrx[i]=arr2[i].substring(0,dex);
								arry[i]=arr2[i].substring(dex+1);
							}
							N=Math.max(...arry);
	                        W=Math.min(...arrx);
	                        E=Math.max(...arrx);  
	                        S=Math.min(...arry);
	                        flag=0;
                        }
                        if (flag) {
                        	alert("Wrong kml!");
                        }else{
                        	$("#zwd").prop("value", N);
	                        $("#zjd").prop("value", W);
	                        $("#yjd").prop("value", E);    
	                        $("#ywd").prop("value", S);
                        	var coordinatesPolygon = [];
                        	var pointTransform = ol.proj.fromLonLat([W,N], "EPSG:3857");
                        	coordinatesPolygon.push(pointTransform);
                        	var pointTransform = ol.proj.fromLonLat([E,N], "EPSG:3857");
                        	coordinatesPolygon.push(pointTransform);
                        	var pointTransform = ol.proj.fromLonLat([E,S], "EPSG:3857");
                        	coordinatesPolygon.push(pointTransform);
                        	var pointTransform = ol.proj.fromLonLat([W,S], "EPSG:3857");
                        	coordinatesPolygon.push(pointTransform);
                        	//console.log(coordinatesPolygon);
                        	var plygon = new ol.geom.Polygon([coordinatesPolygon]);
                        	var polygonFeature = new ol.Feature({
					        	geometry: plygon
                        	});
                                
                        	var source = new ol.source.Vector({
					            features: [
					                polygonFeature
					            ]
					        });
					        var vectorLayer = new ol.layer.Vector({
					            source: source,
                                                    name: 'kmllayer',
					            style: style
					            })

        					map.addLayer(vectorLayer);
                                                $("#zwd").prop("value", N);
                                                $("#zjd").prop("value", W);
                                                $("#yjd").prop("value", E);
                                                $("#ywd").prop("value", S);                                 
                                                //map.getView().setCenter(ol.proj.transform([(W+E)/2, (N+S)/2], 'EPSG:4326', 'EPSG:3857'));
                                                var myextent = [W, S, E, N];
                                                myextent=ol.proj.transformExtent(myextent, 'EPSG:4326', 'EPSG:3857');
                                                map.getView().fit(myextent);          
                        }
                    }
                    
                    var f = document.getElementById("uploadfile").files[0];
                    reader.readAsText(f);
                    document.getElementById('uploadfile').value = null; 
                   
                })
            })
