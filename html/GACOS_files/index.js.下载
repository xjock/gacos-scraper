var style = new ol.style.Style({
    fill: new ol.style.Fill({
        color: 'rgba(255,255,255, 0.4)'
    }),
    //划线的时候的图样
    stroke: new ol.style.Stroke({
        color: 'rgba(30,144,255, 1)',
        width: 2
    }),
    image: new ol.style.Circle({
        radius: 5,
        stroke: new ol.style.Stroke({
            color: 'rgba(30,144,255, 1)'
        }),
        fill: new ol.style.Fill({
            color: 'rgba(255,255,255, 0.4)'
        })
    })
});

var esriMapLayer = new ol.layer.Tile({
    source: new ol.source.XYZ({
        url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
        wrapX: false
    }),
    title:"ESRI影像"
});
//OSM地图
var osmLayer = new ol.layer.Tile({
    source: new ol.source.OSM({wrapX: false}),
    title:"OSM影像"
});
//bing map
var bingMapLayer=new ol.layer.Tile({
    visible: false,
    preload: Infinity,
    source: new ol.source.BingMaps({
    key: 'ArfQNkv9UlDSUlu8oVczcZRHYNiIMx4O2Xk7yQW1cznLEXqyCDzOhw9ihZjgrc3R',
    imagerySet: 'AerialWithLabels',//图层样式
    wrapX: false
        }) 
});

var map=new ol.Map({
// 在地图上添加上面创建的图层，图层顺序自下而上，依次是ESRI地图，OSM地图
    layers: [esriMapLayer, osmLayer ,bingMapLayer],
    view: new ol.View({
        center: ol.proj.transform([5, 52], 'EPSG:4326', 'EPSG:3857'),
        zoom: 6,
        minZoom: 2,
    }),
    target: 'map'
});

function upArcGIS (elem) {
    esriMapLayer.setVisible(elem.click);
    if (elem.click) {
        osmLayer.setVisible(false);
        bingMapLayer.setVisible(false);
    }
}
 
// 置顶osm图层到最上面
function upOSM (elem) {
    osmLayer.setVisible(elem.click);
    if (elem.click) {
        esriMapLayer.setVisible(false);
        bingMapLayer.setVisible(false);
    }
}

function upBingMap(elem){
    bingMapLayer.setVisible(elem.click)
    if (elem.click) {
    	esriMapLayer.setVisible(false);
    	osmLayer.setVisible(false);
    }
}

var source = new ol.source.Vector();
var layer = new ol.layer.Vector({
    source: source,
    style: style
});
 
var draw = new ol.interaction.Draw({
    source: layer.getSource(),
    type: 'Circle',
    style: style,
    geometryFunction: ol.interaction.Draw.createBox()
});
 
function clickHandler(e1) {
    $('#map').bind("click", function (e) { 
        var pointermove = $('#map').bind("pointermove", function (e2) {
            var coordinate = ol.proj.transform(map.getEventCoordinate(e2), 'EPSG:3857', 'EPSG:4326');
            $("#yjd").prop("value", coordinate[0].toFixed(6));
            $("#ywd").prop("value", coordinate[1].toFixed(6));
        }).bind("click", function () {
            $("#map").off('pointermove');
            $("#map").off('click');
        });
        if ($("#zjd").val() == "" && $("#zwd").val() == "") {
            var coordinate = ol.proj.transform(map.getEventCoordinate(e), 'EPSG:3857', 'EPSG:4326');
            $("#zjd").prop("value", coordinate[0].toFixed(6));
            $("#zwd").prop("value", coordinate[1].toFixed(6));
        }
    });
    if ("Cancel" == ($("#btnclick").text())) {
        $("#btnclick").text("Draw from map");
        $("input.local").prop("value", "");
        layer.getSource().clear();
        map.removeLayer(layer);
        $("#map").off('pointermove');
        $("#map").off('click'); 
        map.removeInteraction(draw);
        map.getLayers().getArray().filter(layer => layer.get('name') === 'kmllayer').forEach(layer => map.removeLayer(layer)); 
     
    } else {
        $("#btnclick").text("Cancel");
        $("input.local").prop("value", "");
        map.addInteraction(draw);
    }
}
draw.on('drawend', function () {
    map.addLayer(layer);
    map.removeInteraction(draw);
});
